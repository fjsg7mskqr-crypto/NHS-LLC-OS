# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# AI
ANTHROPIC_API_KEY=your_key
OPENAI_API_KEY=sk-proj-your_key

# Shared Assistant Service
ASSISTANT_SERVICE_TOKEN=generate_with_openssl_rand_hex_32

# Discord
DISCORD_BOT_TOKEN=your_bot_token
DISCORD_PUBLIC_KEY=your_public_key
DISCORD_APPLICATION_ID=your_app_id
DISCORD_GUILD_ID=your_guild_id
DISCORD_CHANNEL_ID=your_channel_id
DISCORD_USER_ID=your_user_id

# Square
SQUARE_ACCESS_TOKEN=your_square_token
SQUARE_LOCATION_ID=your_location_id
SQUARE_ENVIRONMENT=sandbox

# Vercel Cron
CRON_SECRET=generate_with_openssl_rand_hex_32

# Auth
AUTHORIZED_GITHUB_LOGINS=your_github_username

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://publicKey@example.ingest.sentry.io/projectId
SENTRY_DSN=https://publicKey@example.ingest.sentry.io/projectId
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your_sentry_org_slug
SENTRY_PROJECT=your_sentry_project_slug
